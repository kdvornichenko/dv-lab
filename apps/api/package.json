{
	"name": "@teacher-crm/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "node --import tsx src/local-server.ts",
		"build": "rimraf dist && tsup --config tsup.config.ts",
		"start": "node --enable-source-maps dist/local-server.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit",
		"test": "node --import tsx src/app.test.ts && node --import tsx src/db.integration.test.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.6",
		"@hono/zod-validator": "^0.7.6",
		"@supabase/supabase-js": "^2.49.4",
		"@teacher-crm/api-types": "*",
		"@teacher-crm/db": "*",
		"@teacher-crm/rbac": "*",
		"dotenv": "^16.4.5",
		"hono": "^4.10.7",
		"zod": "^3.24.3"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"rimraf": "^6.0.1",
		"tsup": "^8.5.0",
		"tsx": "^4.20.6",
		"typescript": "^5.6.3"
	}
}
