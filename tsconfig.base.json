{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"incremental": true,
		"paths": {
			"@teacher-crm/api-types": ["./packages/api-types/src/index.ts"],
			"@teacher-crm/db": ["./packages/db/src/index.ts"],
			"@teacher-crm/rbac": ["./packages/rbac/src/index.ts"]
		}
	}
}
