{
	"name": "teacher-english-crm",
	"version": "0.1.0",
	"private": true,
	"packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev --filter=@teacher-crm/api --filter=@teacher-crm/web",
		"build": "turbo run build",
		"build:apps": "turbo run build --filter=@teacher-crm/api --filter=@teacher-crm/web",
		"start": "turbo run start --filter=@teacher-crm/api --filter=@teacher-crm/web",
		"prod": "yarn build && yarn start",
		"typecheck": "turbo run typecheck",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"format": "prettier --write . --config .prettierrc.json --cache --cache-location .cache/prettier",
		"format:check": "prettier --check . --config .prettierrc.json --cache --cache-location .cache/prettier",
		"db:generate": "yarn --cwd packages/db db:generate",
		"db:migrate": "yarn --cwd packages/db db:migrate",
		"db:studio": "yarn --cwd packages/db db:studio"
	},
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^5.2.2",
		"prettier": "^3.6.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"turbo": "^2.9.6",
		"typescript": "^5.6.3"
	}
}
